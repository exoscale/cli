# Test: dbaas update --help-pg displays all PostgreSQL-specific flags
# Verifies that the new configuration flags are properly registered
# on the update command as well.

exec exo dbaas update --help-pg
stdout '--pg-shared-buffers-percentage'
stdout '--pg-synchronous-replication'
stdout '--pg-timescaledb-settings'
stdout '--pg-variant'
stdout '--pg-work-mem'

# Also verify pre-existing flags are still present
stdout '--pg-settings'
stdout '--pg-bouncer-settings'
stdout '--pg-ip-filter'
stdout '--pg-backup-schedule'

-- .config/exoscale/exoscale.toml --
defaultaccount = "test"

[[accounts]]
name = "test"
key = "EXO000000000000000000"
secret = "dummy-secret-for-help-test"
defaultZone = "ch-gva-2"
